{
  "_meta": {
    "purpose": "광명시 고1 1학기 중간 기출 28개 중/하 난이도 유형 분류 체계",
    "audience": "30~50점 학생이 3일 내 득점 가능한 기본 패턴 중심",
    "policy": [
      "상위 유형은 교육과정 소단원 기반",
      "소분류는 '문제를 보자마자 어떤 풀이 루틴을 가동할지' 기준",
      "한 문항에 여러 소분류가 걸리면 '주된 풀이 루틴' 쪽으로 라벨"
    ]
  },
  "types": {
    "다항식의 연산": [
      {"id": "P1", "label": "다항식 덧셈·뺄셈·스칼라배", "cue": "A, B 다항식 주어지고 2A-B 같은 계산"},
      {"id": "P2", "label": "곱셈공식 전개", "cue": "(a+b)², (a+b+c)² 기본 전개"},
      {"id": "P3", "label": "곱셈공식 변형 (합·곱→제곱합)", "cue": "a+b, ab → a²+b², (a-b)² 값"},
      {"id": "P4", "label": "세제곱 공식 (a³±b³, (a±b)³)", "cue": "세제곱 합·차"},
      {"id": "P5", "label": "곱셈공식 숫자 계산", "cue": "999×1001, 100² 등 큰 수 치환"},
      {"id": "P6", "label": "다항식 나눗셈 (직접 장제법)", "cue": "몫·나머지를 직접 구함"},
      {"id": "P7", "label": "조립제법 - 과정 빈칸", "cue": "조립제법 표에서 a, b, c 값 찾기"},
      {"id": "P8", "label": "조립제법 몫·나머지", "cue": "x-α로 나눈 Q(x), R 계산"}
    ],
    "항등식과 나머지정리": [
      {"id": "H1", "label": "항등식 미정계수 (계수비교)", "cue": "양변 전개해서 계수 비교"},
      {"id": "H2", "label": "항등식 미정계수 (수치대입)", "cue": "x=0,1,-1 대입해서 연립"},
      {"id": "H3", "label": "나머지정리 (1차식으로 나눈 나머지)", "cue": "x-α로 나누면 P(α)"},
      {"id": "H4", "label": "조건부 나머지 (두 나머지→합성 나머지)", "cue": "x-1로 나눈 나머지 A, x-2로 나눈 나머지 B 주고 (x-1)(x-2)로 나눈 나머지"},
      {"id": "H5", "label": "인수정리·1차 인수 찾기", "cue": "P(α)=0 이면 x-α 인수"}
    ],
    "인수분해": [
      {"id": "F1", "label": "공식 기반 기본 인수분해", "cue": "a²-b², a³±b³, 완전제곱 1회 적용"},
      {"id": "F2", "label": "공통인수·치환 인수분해", "cue": "공통부분을 문자로 치환"},
      {"id": "F3", "label": "복이차식 인수분해", "cue": "x⁴+ax²+b 꼴"},
      {"id": "F4", "label": "삼차·사차 다항식 인수분해 (조립제법)", "cue": "P(x) 고차식을 조립제법으로 인수분해"},
      {"id": "F5", "label": "인수분해 이용 숫자 계산", "cue": "999²-1, 101³+... 같은 큰 수 계산"}
    ],
    "복소수": [
      {"id": "C1", "label": "i의 거듭제곱·규칙", "cue": "i^n 단순화"},
      {"id": "C2", "label": "i 거듭제곱의 합·수열", "cue": "i+i²+...+i^n 합"},
      {"id": "C3", "label": "복소수 사칙연산·유리화", "cue": "분수형 복소수 a+bi로 정리"},
      {"id": "C4", "label": "복소수 상등 (실·허수부 비교)", "cue": "좌우변 실수부=실수부, 허수부=허수부"},
      {"id": "C5", "label": "켤레복소수 연산·성질", "cue": "ẑ, z·ẑ, z+ẑ"},
      {"id": "C6", "label": "음수 제곱근·√(-a)", "cue": "√(-8)·√(-2) 등 음수 제곱근 계산"}
    ],
    "이차방정식": [
      {"id": "Q1", "label": "이차방정식 풀이 (인수분해/근의공식)", "cue": "해를 직접 구함"},
      {"id": "Q2", "label": "판별식 - 실근·허근·중근 판정", "cue": "D>0, D=0, D<0"},
      {"id": "Q3", "label": "판별식 - 실근/허근 조건식 구하기", "cue": "D≥0인 k의 범위"},
      {"id": "Q4", "label": "근과 계수의 관계 - 기본", "cue": "α+β, αβ 바로 활용"},
      {"id": "Q5", "label": "근과 계수의 관계 - 대칭식", "cue": "α²+β², 1/α+1/β, α³+β³"},
      {"id": "Q6", "label": "두 근으로 이차방정식 만들기", "cue": "α+β=s, αβ=p → x²-sx+p=0"},
      {"id": "Q7", "label": "공통근 문제", "cue": "두 이차방정식이 공통근을 가진다"},
      {"id": "Q8", "label": "허근·켤레근 활용", "cue": "허근 α일 때 α̅도 근, α·α̅"},
      {"id": "Q9", "label": "이차방정식 실근 판정 (보기형)", "cue": "<보기> 중 실근 갖는 것"}
    ],
    "이차함수": [
      {"id": "Y1", "label": "일반형↔표준형 변환", "cue": "y=ax²+bx+c → y=a(x-p)²+q"},
      {"id": "Y2", "label": "꼭짓점·축·대칭축", "cue": "꼭짓점 좌표, 축의 방정식"},
      {"id": "Y3", "label": "이차함수 최댓값·최솟값 (전체 실수)", "cue": "꼭짓점 y값"},
      {"id": "Y4", "label": "제한된 정의역의 최대·최소", "cue": "a≤x≤b에서 최댓·최솟값"},
      {"id": "Y5", "label": "정의역이 변수 범위일 때 최소·최대", "cue": "k≤x≤k+1에서의 최댓값 m"},
      {"id": "Y6", "label": "이차함수와 x축 교점 (판별식 조건)", "cue": "x축과 만나지 않게/한 점에서/두 점에서"},
      {"id": "Y7", "label": "이차함수와 직선 위치관계", "cue": "두 교점의 x좌표, 판별식"},
      {"id": "Y8", "label": "이차함수 그래프 평행이동", "cue": "x축·y축 방향 이동"},
      {"id": "Y9", "label": "이차함수 결정 (조건→식)", "cue": "주어진 조건에서 이차함수 f(x) 구하기"},
      {"id": "Y10", "label": "이차함수 활용 - 도형 넓이", "cue": "삼각형/사각형 넓이 최대"},
      {"id": "Y11", "label": "이차함수 고정점 (k 무관 통과점)", "cue": "실수 k의 값에 관계없이 항상 지나는 점"}
    ]
  }
}
